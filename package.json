{
  "name": "quark-link-parser-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:desktop": "npm run build:server && npm run build:electron && concurrently \"npm run dev:client\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist-electron/electron/main.js\"",
    "electron:dev": "npm run dev:desktop",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vue-tsc --noEmit && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:desktop": "npm run build && npm run build:electron && electron-builder --win portable",
    "dist:win": "npm run build:desktop"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.4",
    "axios": "^1.7.9",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.local.quarkdesktop",
    "productName": "Quark Desktop MVP",
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/aria2",
        "to": "aria2",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/yt-dlp",
        "to": "yt-dlp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
